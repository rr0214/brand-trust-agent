# ─────────────────────────────────────────────────────────────────────────────
# Brand Trust Agent — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key — used for LLM calls (gpt-4o-mini) and embeddings (text-embedding-3-small)
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Arize AX credentials — used to stream traces to your Arize project
# Get at: https://app.arize.com → Settings → API Keys
ARIZE_SPACE_ID=your_space_id_here
ARIZE_API_KEY=your_api_key_here
